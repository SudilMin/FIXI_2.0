<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fixi_bottle">
  <xacro:property name="base_length" value="0.58"/>
  <xacro:property name="base_width" value="0.42"/>
  <xacro:property name="base_height" value="0.16"/>
  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_width" value="0.045"/>
  <xacro:property name="wheel_y" value="${base_width / 2.0 + wheel_width / 2.0 + 0.01}"/>
  <xacro:property name="wheel_x" value="-0.04"/>
  <xacro:property name="wheel_z" value="0.05"/>
  <xacro:property name="caster_radius" value="0.035"/>
  <xacro:property name="arm_base_z" value="${base_height + 0.035}"/>

  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${mass * (y * y + z * z) / 12.0}"
        ixy="0"
        ixz="0"
        iyy="${mass * (x * x + z * z) / 12.0}"
        iyz="0"
        izz="${mass * (x * x + y * y) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertial" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${mass * (3.0 * radius * radius + length * length) / 12.0}"
        ixy="0"
        ixz="0"
        iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}"
        iyz="0"
        izz="${mass * radius * radius / 2.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="ultrasonic_sensor" params="name x y z yaw">
    <link name="${name}_ultrasonic_link">
      <visual>
      <material name="mat_1"><color rgba="0.401 0.5 0.5 1.0"/></material>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.055 0.025"/>
        </geometry>
        
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.055 0.025"/>
        </geometry>
      </collision>
      <xacro:box_inertial mass="0.05" x="0.035" y="0.055" z="0.025"/>
    </link>

    <joint name="${name}_ultrasonic_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}_ultrasonic_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 ${yaw}"/>
    </joint>

    <link name="${name}_ultrasonic_frame"/>

    <joint name="${name}_ultrasonic_frame_joint" type="fixed">
      <parent link="${name}_ultrasonic_link"/>
      <child link="${name}_ultrasonic_frame"/>
      <origin xyz="0.025 0 0" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  
  
  
  
  

  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <material name="mat_2"><color rgba="0.402 0.5 0.5 1.0"/></material>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="8.0" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <xacro:property name="wheel_x_offset" value="0.18"/>

  <xacro:macro name="drive_wheel" params="prefix x_reflect y_reflect mat_id">
    <link name="${prefix}_wheel_link">
      <visual>
        <material name="mat_${mat_id}"><color rgba="0.4 0.5 0.5 1.0"/></material>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertial mass="0.6" radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${wheel_x_offset * x_reflect} ${wheel_y * y_reflect} ${-base_height / 2.0 + wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="100.0" velocity="20.0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="front_left" x_reflect="1" y_reflect="1" mat_id="101"/>
  <xacro:drive_wheel prefix="front_right" x_reflect="1" y_reflect="-1" mat_id="102"/>
  <xacro:drive_wheel prefix="rear_left" x_reflect="-1" y_reflect="1" mat_id="103"/>
  <xacro:drive_wheel prefix="rear_right" x_reflect="-1" y_reflect="-1" mat_id="104"/>

  <link name="camera_mount_link">
    <visual>
      <material name="mat_6"><color rgba="0.406 0.5 0.5 1.0"/></material>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.05"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.05"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.25" x="0.10" y="0.08" z="0.05"/>
  </link>

  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_mount_link"/>
    <origin xyz="0.34 0 0.09" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <material name="mat_7"><color rgba="0.40700000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.045 0.09 0.045"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.045 0.09 0.045"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.15" x="0.045" y="0.09" z="0.045"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_mount_link"/>
    <child link="camera_link"/>
    <origin xyz="0.06 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0.025 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <xacro:ultrasonic_sensor
    name="front"
    x="${base_length / 2.0 + 0.015}"
    y="0"
    z="0.02"
    yaw="0"/>
  <xacro:ultrasonic_sensor
    name="left"
    x="0.02"
    y="${base_width / 2.0 + 0.015}"
    z="0.02"
    yaw="1.5708"/>
  <xacro:ultrasonic_sensor
    name="right"
    x="0.02"
    y="${-base_width / 2.0 - 0.015}"
    z="0.02"
    yaw="-1.5708"/>
  <xacro:ultrasonic_sensor
    name="rear"
    x="${-base_length / 2.0 - 0.015}"
    y="0"
    z="0.02"
    yaw="3.1416"/>

  <link name="storage_bin_link">
    <visual>
      <material name="mat_8"><color rgba="0.40800000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.32 0.18"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.32 0.18"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.8" x="0.22" y="0.32" z="0.18"/>
  </link>

  <joint name="storage_bin_joint" type="fixed">
    <parent link="base_link"/>
    <child link="storage_bin_link"/>
    <origin xyz="-0.16 0 0.16" rpy="0 0 0"/>
  </joint>

  <link name="arm_base_link">
    <visual>
      <material name="mat_9"><color rgba="0.40900000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.05"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.4" radius="0.055" length="0.05"/>
  </link>

  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0.05 0 ${arm_base_z}" rpy="0 0 0"/>
  </joint>

  <link name="arm_shoulder_link">
    <visual>
      <material name="mat_10"><color rgba="0.41000000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.055 0.055 0.16"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.055 0.055 0.16"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.35" x="0.055" y="0.055" z="0.16"/>
  </link>

  <joint name="arm_joint_1_yaw" type="revolute">
    <parent link="arm_base_link"/>
    <child link="arm_shoulder_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10.0" velocity="1.5"/>
  </joint>

  <link name="arm_upper_link">
    <visual>
      <material name="mat_11"><color rgba="0.41100000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0.10 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.027" length="0.20"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0.10 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.027" length="0.20"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.3" radius="0.027" length="0.20"/>
  </link>

  <joint name="arm_joint_2_shoulder" type="revolute">
    <parent link="arm_shoulder_link"/>
    <child link="arm_upper_link"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.4" effort="10.0" velocity="1.2"/>
  </joint>

  <link name="arm_forearm_link">
    <visual>
      <material name="mat_12"><color rgba="0.41200000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.18"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.18"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.25" radius="0.024" length="0.18"/>
  </link>

  <joint name="arm_joint_3_elbow" type="revolute">
    <parent link="arm_upper_link"/>
    <child link="arm_forearm_link"/>
    <origin xyz="0.20 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.6" upper="1.6" effort="8.0" velocity="1.2"/>
  </joint>

  <link name="arm_wrist_link">
    <visual>
      <material name="mat_13"><color rgba="0.41300000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0.045 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.09"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0.045 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.09"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.18" radius="0.022" length="0.09"/>
  </link>

  <joint name="arm_joint_4_wrist" type="revolute">
    <parent link="arm_forearm_link"/>
    <child link="arm_wrist_link"/>
    <origin xyz="0.18 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.5"/>
  </joint>

  <link name="gripper_base_link">
    <visual>
      <material name="mat_14"><color rgba="0.41400000000000003 0.5 0.5 1.0"/></material>
      <origin xyz="0.025 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.08 0.035"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0.025 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.08 0.035"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.12" x="0.05" y="0.08" z="0.035"/>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="arm_wrist_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0.09 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_gripper_finger_link">
    <visual>
      <material name="mat_15"><color rgba="0.41500000000000004 0.5 0.5 1.0"/></material>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.018 0.025"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.018 0.025"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.04" x="0.08" y="0.018" z="0.025"/>
  </link>

  <joint name="left_gripper_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="left_gripper_finger_link"/>
    <origin xyz="0.05 0.04 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.035" effort="2.0" velocity="0.05"/>
  </joint>

  <link name="right_gripper_finger_link">
    <visual>
      <material name="mat_16"><color rgba="0.41600000000000004 0.5 0.5 1.0"/></material>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.018 0.025"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.018 0.025"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.04" x="0.08" y="0.018" z="0.025"/>
  </link>

  <joint name="right_gripper_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="right_gripper_finger_link"/>
    <origin xyz="0.05 -0.04 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.035" effort="2.0" velocity="0.05"/>
    <mimic joint="left_gripper_finger_joint" multiplier="1.0" offset="0.0"/>
  </joint>

  <link name="gripper_tcp"/>

  <joint name="gripper_tcp_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="gripper_tcp"/>
    <origin xyz="0.14 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Include Gazebo simulation settings -->
  <xacro:include filename="$(find fixi_description)/urdf/fixi.gazebo.xacro"/>
</robot>
